# Training Dockerfile for Vertex AI Custom Training
# torch 2.6.0 + CUDA 12.4 — required: unsloth_zoo>=2026.3 pulls torchao>=0.13 which needs torch.int1 (added in 2.6)
FROM pytorch/pytorch:2.6.0-cuda12.4-cudnn9-devel

WORKDIR /app

RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

# Pin torch version explicitly so pip install unsloth does NOT upgrade it
# xformers omitted — version must match torch exactly; unsloth works without it
RUN pip install --no-cache-dir \
    "torch==2.6.0" \
    "unsloth" \
    "trl" \
    "peft" \
    "accelerate" \
    "bitsandbytes" \
    "datasets>=2.16.0" \
    "wandb>=0.16.0" \
    "sentencepiece" \
    "protobuf" \
    "google-cloud-storage" \
    "openai>=1.0.0"

# Copy all scripts and training data
COPY scripts/ scripts/
COPY training_data/ training_data/

ENV DATASET_PATH=training_data/teacher_dataset_20260302.jsonl
ENV OUTPUT_DIR=/app/output/llama3-purchasing-sft
ENV WANDB_PROJECT=purchasing-automation-sft

CMD ["python", "scripts/train_sft.py"]
